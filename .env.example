# --- Database (Neon via Vercel Marketplace) ---------------------------------
# Vercel dashboard → Storage → Create Database → Neon, then `vercel env pull`.
DATABASE_URL=

# --- AgentCash router: payments ----------------------------------------------
# Public origin agents will hit. Auto-derived on plain Vercel domains; set
# explicitly once a custom domain is attached. Load-bearing for 402 matching.
BASE_URL=

# Platform wallet: receives the $0.15 registration fees and fallback payouts
# for legacy entries without a creator wallet. 0x-prefixed EVM address.
EVM_PAYEE_ADDRESS=

# x402 on Base. Coinbase Developer Platform (free tier):
# https://portal.cdp.coinbase.com/projects/api-keys  (Server key)
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# MPP on Tempo enables the second payment protocol (recommended).
# MPP_SECRET_KEY: `openssl rand -hex 32`. It must persist across deploys.
# MPP_CURRENCY: Tempo USDC.
MPP_SECRET_KEY=
MPP_CURRENCY=0x20c000000000000000000000b9537d11c60e8b50

# --- Script audits -----------------------------------------------------------
# Registrations ($0.15) fund an LLM security audit. In local environments the
# service can fall back to the agentcash CLI; serverless production needs a key.
ANTHROPIC_API_KEY=
# AUDIT_MODEL=claude-opus-4-8

# --- X identity --------------------------------------------------------------
# OAuth 2.0 app from developer.x.com. Register this callback URL:
# {BASE_URL}/api/identity/callback
X_OAUTH_CLIENT_ID=
# Required for confidential clients. Leave empty for a public PKCE client.
X_OAUTH_CLIENT_SECRET=

# --- Production hardening ------------------------------------------------------
# Upstash Redis (Vercel Marketplace → Upstash for Redis). Backs SIWX nonces and
# MPP replay protection across serverless instances. Add before real traffic.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Strong secret required by POST /api/admin/delist.
ADMIN_TOKEN=

# Optional: Base Builder Code for on-chain attribution (dashboard.base.org).
# X402_BUILDER_CODE=
